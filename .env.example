# Copy to .env and adjust. All values have sensible defaults — the app runs
# fully without any of these set (the Claude layer degrades gracefully).

# --- Claude / GenAI layer (optional) ---
# Without a key, /analyze returns a deterministic templated analysis instead.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# --- Storage ---
DATABASE_URL=sqlite:///./watchdog.db

# --- Detection tuning ---
BUCKET_SECONDS=60        # time-window size for error-rate bucketing
BASELINE_WINDOW=3        # number of trailing buckets used as the rolling baseline
ZSCORE_THRESHOLD=3.0     # flag a bucket when error count is this many std-devs above baseline
MIN_ERROR_COUNT=3        # ignore spikes below this absolute error count (noise floor)

# --- Alerting ---
# Severity (low|medium|high|critical) at/above which a webhook fires.
ALERT_SEVERITY=high
# External webhook URL. Leave blank to "simulate" delivery (recorded, not sent).
WEBHOOK_URL=
